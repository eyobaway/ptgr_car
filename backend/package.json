{
    "name": "realtor-backend",
    "version": "1.0.0",
    "description": "Backend for Realtor Clone",
    "main": "dist/server.js",
    "scripts": {
        "start": "node dist/server.js",
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "tsc",
        "test": "jest",
        "migrate": "sequelize db:migrate",
        "seed": "sequelize db:seed:all",
        "generate-docs": "tsoa spec-and-routes"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1016.0",
        "@google/generative-ai": "^0.24.1",
        "@types/multer-s3": "^3.0.3",
        "axios": "^1.14.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.1",
        "express": "^4.18.2",
        "google-auth-library": "^10.6.2",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "multer-s3": "^3.0.1",
        "mysql2": "^3.9.1",
        "reflect-metadata": "^0.2.1",
        "sequelize": "^6.37.1",
        "sequelize-typescript": "^2.1.6",
        "sharp": "^0.34.5",
        "socket.io": "^4.8.3",
        "swagger-ui-express": "^5.0.0",
        "tsoa": "^6.0.1",
        "uuid": "^13.0.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.12",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.11.16",
        "@types/sharp": "^0.31.1",
        "@types/supertest": "^6.0.2",
        "@types/swagger-ui-express": "^4.1.6",
        "@types/uuid": "^10.0.0",
        "jest": "^29.7.0",
        "sequelize-cli": "^6.6.2",
        "supertest": "^6.3.4",
        "ts-jest": "^29.1.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    }
}
